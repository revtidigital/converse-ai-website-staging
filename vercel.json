{
  "functions": {
    "api/serve-blog.ts": {
      "includeFiles": "dist/index.html"
    }
  },
  "routes": [

  {
      "src": "/(.*)",
      "headers": { "X-Robots-Tag": "noindex, nofollow" },
      "continue": true
    },
    {
      "src": "/storage/(.*)",
      "dest": "https://njtfddsnsxlxlimuvhfa.supabase.co/storage/$1"
    },
    {
      "src": "/wp-content/uploads/(.*)",
      "dest": "https://njtfddsnsxlxlimuvhfa.supabase.co/storage/v1/object/public/blog-images/wp-content/$1"
    },
    {
      "src": "/(?!(api|assets|favicon|logo|sitemap|robots\\.txt|wp-content|faq).*).*",
      "has": [
        {
          "type": "host",
          "value": "(blog\\.theconverseai\\.com|blog2\\.staging\\.theconverseai\\.com|localhost:5173)"
        }
      ],
      "dest": "/api/serve-blog"
    },

    {
      "src": "/sitemap.xml",
      "dest": "/api/sitemap"
    },
    {
      "src": "/sitemap-blogs.xml",
      "dest": "/api/sitemap-blogs"
    },
    { "handle": "filesystem" },

    {
      "src": "/(.*\\.(ico|png|jpg|jpeg|svg|css|js|woff|woff2))",
      "dest": "/$1"
    },

    {
      "src": "/faq",
      "status": 410
    },
    {
      "src": "/faq_cat/(.*)",
      "status": 410
    },
    {
      "src": "/(.*)/page/(.*)",
      "status": 410
    },
    {
      "src": "/product/theconverseai.com/(.*)",
      "status": 410
    },
    {
      "src": "/wp-content/(.*)",
      "status": 410
    },

    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0" }
    }
  ]
}
