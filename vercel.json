{

  
  "routes": [

  {
      "src": "/storage/(.*)",
      "dest": "https://njtfddsnsxlxlimuvhfa.supabase.co/storage/$1"
    },

    {
      "src": "/sitemap.xml",
      "dest": "/api/sitemap"
    },
    {
      "src": "/sitemap-blogs.xml",
      "dest": "/api/sitemap-blogs"
    },
    { "handle": "filesystem" },

    {
      "src": "/(.*\\.(ico|png|jpg|jpeg|svg|css|js|woff|woff2))",
      "dest": "/$1"
    },

    {
      "src": "/faq",
      "status": 410
    },
    {
      "src": "/faq_cat/(.*)",
      "status": 410
    },
    {
      "src": "/(.*)/page/(.*)",
      "status": 410
    },
    {
      "src": "/product/theconverseai.com/(.*)",
      "status": 410
    },
    {
      "src": "/wp-content/(.*)",
      "status": 410
    },

    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0" }
    }
  ]
}
