# Server-only xAI API key. Configure in Vercel project settings; never expose to browser code.
XAI_API_KEY=replace-with-server-side-xai-api-key

# Public feature flag for the deployed xAI Speech-to-Speech orb.
VITE_XAI_VOICE_ENABLED=false

# Optional comma-separated origins allowed to request ephemeral xAI realtime tokens.
XAI_TOKEN_ALLOWED_ORIGINS=https://example.com
